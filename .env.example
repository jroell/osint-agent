# --- Core ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Local testing only: bypass Firebase auth and DB-backed credit/event accounting.
DEV_AUTH_BYPASS=false

# --- Postgres ---
# Host port 5434 maps to container 5432 (see infra/docker-compose.yml) — chosen to coexist with other local Postgres.
DATABASE_URL=postgres://osint:osint@localhost:5434/osint_dev?sslmode=disable

# --- DragonflyDB (Redis protocol) ---
# Host port 6380 maps to container 6379 — chosen to coexist with other local Redis/Dragonfly.
REDIS_URL=redis://localhost:6380

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=osint-agent-dev
# Either GOOGLE_APPLICATION_CREDENTIALS pointing to a JSON file, or FIREBASE_SERVICE_ACCOUNT_JSON containing the JSON itself
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin-dev.json

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_HUNTER=price_...
STRIPE_PRICE_ID_OPERATOR=price_...

# --- Anthropic (LLM Gateway primary backend) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Worker endpoints + signing ---
# `bun run dev` (or `bun run gen:worker-keys`) auto-generates a matched
# Ed25519 keypair into your local .env. The API signs with the seed; both
# workers verify with the public key.
GO_WORKER_URL=http://localhost:8181
PY_WORKER_URL=http://localhost:8182
WORKER_SIGNING_KEY_HEX=generate-a-32-byte-ed25519-seed-and-hex-encode-it
WORKER_PUBLIC_KEY_HEX=generate-the-matching-32-byte-ed25519-public-key

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20...
OTEL_SERVICE_NAME=osint-api-dev

# --- Billing unit economics ---
CREDIT_PRICE_USD=0.01
