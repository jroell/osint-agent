{
  "name": "@osint/benchmark-suite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bunx tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "run:subdomain-faceoff": "bun src/benchmarks/subdomain-faceoff.ts",
    "run:osint-bench-asset": "bun src/benchmarks/osint-bench-asset.ts",
    "run:osint-bench-people": "bun src/benchmarks/osint-bench-people.ts"
  },
  "dependencies": {
    "@osint/shared-types": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
